---
---

<header class="tech-header">
  <div class="container header-container">
    <div class="brand">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="ElectriOn Logo" width="28" height="28" class="logo-icon" />
        <span class="logo-text">ElectriOn <span class="highlight">Sistemas</span></span>
      </a>
    </div>
    
    <nav class="main-nav">
      <ul>
        <li><a href="#proyectos">Proyectos Industriales</a></li>
        <li><a href="#capacidades">Capacidades</a></li>
        <li><a href="#nosotros">Nosotros</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
    </nav>
    
    <div class="header-actions">
      <a href="#contacto" class="btn btn-primary btn-sm">Solicitar Evaluación</a>
    </div>
  </div>
</header>

<style>
  .tech-header {
    background-color: rgba(7, 19, 36, 0.95); /* Deep navy, slightly transparent */
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 1rem 0;
  }
  
  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  
  .logo-icon {
    font-size: 1.5rem;
  }
  
  .logo-text {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
  
  .highlight {
    color: var(--accent-cyan);
  }
  
  .main-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 2rem;
  }
  
  .main-nav a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    position: relative;
    padding: 0.5rem 0;
  }
  
  .main-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--accent-cyan);
    transition: width 0.3s ease;
  }
  
  .main-nav a:hover {
    color: var(--text-primary);
  }
  
  .main-nav a:hover::after {
    width: 100%;
  }
  
  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }
  
  @media (max-width: 900px) {
    .main-nav {
      display: none; /* Mobile menu logic pending */
    }
  }
</style>
