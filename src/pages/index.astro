---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

// B2B Industrial Systems
const proy_industriales = [
  {
    titulo: "Sistemas Térmicos para Hornos Industriales",
    descripcion: "Diseño, cálculo y automatización de sistemas de calentamiento para hornos de curado de poliuretano y secado industrial. Control PID de alta precisión.",
    etiqueta: "TERMO-ELÉCTRICA",
    icon: "🔥"
  },
  {
    titulo: "Automatización de Prensas Hidráulicas",
    descripcion: "Integración de circuitos de potencia y control térmico con resistencias de cartucho o banda para prensas de vulcanizado y termoformado.",
    etiqueta: "MAQUINARIA PESADA",
    icon: "⚙️"
  },
  {
    titulo: "Ingeniería de Tableros de Control",
    descripcion: "Armado de tableros eléctricos (CCM y PLC) bajo normativas IEC/NEMA. Integración de variadores de frecuencia y contactores de estado sólido.",
    etiqueta: "AUTOMATIZACIÓN",
    icon: "🎛️"
  },
  {
    titulo: "Actualización de Sistemas (Retrofit)",
    descripcion: "Modernización de sistemas de control obsoletos en líneas de producción antiguas, migrando a relés inteligentes y HMI para mayor eficiencia.",
    etiqueta: "MODERNIZACIÓN",
    icon: "🔄"
  }
];
---

<BaseLayout title="Ingeniería en Sistemas Eléctricos Industriales">
  <Header />

  <main class="container">
    <!-- HERO SECTION -->
    <section id="inicio" class="hero-tech">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="label-tech">ESPECIALISTAS B2B</span>
          <h1>Ingeniería de <span class="highlight">Potencia y Control</span> Industrial</h1>
          <p class="lead-tech">Diseñamos e implementamos sistemas eléctricos completos para maquinaria pesada, plantas de producción y procesos térmicos especializados.</p>
          <div class="hero-actions">
            <a href="#proyectos" class="btn btn-primary">Catálogo de Soluciones</a>
            <a href="#contacto" class="btn btn-outline">Coordinar Inspección</a>
          </div>
        </div>
        
        <div class="hero-visual">
          <!-- Stylized Technical Blueprint Graphic -->
          <div class="blueprint-graphic">
            <div class="circuit-line line-1"></div>
            <div class="circuit-line line-2"></div>
            <div class="circuit-line line-3"></div>
            <div class="node node-a"></div>
            <div class="node node-b"></div>
            <div class="node node-c"></div>
            <div class="data-box">SYS_READY</div>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- CAPABILITIES / PROJECTS SECTION -->
    <section id="proyectos" class="systems-section">
      <div class="section-heading">
        <h2>Capacidades del Sistema</h2>
        <p class="subtitle-tech">Desarrollo llave en mano para optimización de procesos térmicos y motrices.</p>
      </div>

      <div class="grid grid-cols-2">
        {proy_industriales.map(proy => (
          <article class="technical-panel">
            <div class="panel-header">
              <span class="tech-icon">{proy.icon}</span>
              <span class="label-tech">{proy.etiqueta}</span>
            </div>
            <h3>{proy.titulo}</h3>
            <p>{proy.descripcion}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- METRICS / TRUST SECTION -->
    <section id="capacidades" class="metrics-section">
      <div class="technical-panel metrics-panel">
        <div class="grid grid-cols-3">
          <div class="metric">
            <div class="metric-value">IEC</div>
            <div class="metric-label">Estándares Internacionales</div>
          </div>
          <div class="metric">
            <div class="metric-value">PID</div>
            <div class="metric-label">Control Térmico Exacto</div>
          </div>
          <div class="metric">
            <div class="metric-value">24x7</div>
            <div class="metric-label">Soporte Operativo</div>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- CONTACT SECTION -->
    <section id="contacto" class="contact-section">
      <div class="grid grid-cols-2 align-center">
        <div class="contact-info">
          <span class="label-tech">ATENCIÓN CORPORATIVA</span>
          <h2>Inicie su <span class="highlight">Proyecto Industrial</span></h2>
          <p>Nuestros ingenieros estructurales están listos para analizar los diagramas unifilares y térmicos de su próxima máquina o línea de ensamble.</p>
          
          <div class="tech-specs-list">
            <div class="spec-row">
              <span class="spec-term">Cobertura:</span>
              <span class="spec-def">Arequipa, Moquegua y Proyectos de Envergadura Nacional</span>
            </div>
            <div class="spec-row">
              <span class="spec-term">Tiempo de Respuesta:</span>
              <span class="spec-def">&lt; 24 Horas para Plantas Industriales</span>
            </div>
          </div>
        </div>
        
        <div class="contact-action">
          <div class="technical-panel cta-panel">
            <h3 class="text-center">Línea Técnica Directa</h3>
            <div class="phone-display">+51 951 413 458</div>
            <a href="https://wa.me/51951413458" class="btn btn-primary btn-block" target="_blank" rel="noopener noreferrer">
              INICIAR PROTOCOLO DE COMUNICACIÓN
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</BaseLayout>

<style>
  /* Hero Section */
  .hero-tech {
    padding: 6rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin-bottom: 1.5rem;
  }

  .highlight {
    color: var(--accent-cyan);
  }

  .lead-tech {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
  }

  /* Blueprint Graphic Simulation */
  .blueprint-graphic {
    width: 100%;
    height: 400px;
    border: 1px solid var(--accent-cyan);
    position: relative;
    background-color: var(--bg-panel);
    overflow: hidden;
  }

  .circuit-line {
    position: absolute;
    background-color: var(--accent-cyan);
    box-shadow: 0 0 8px var(--accent-cyan-dim);
  }

  .line-1 { top: 20%; left: 0; width: 60%; height: 2px; }
  .line-2 { top: 20%; left: 60%; width: 2px; height: 40%; }
  .line-3 { top: 60%; left: 60%; width: 40%; height: 2px; }

  .node {
    position: absolute;
    width: 12px;
    height: 12px;
    background-color: var(--bg-dark);
    border: 2px solid var(--accent-cyan);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .node-a { top: 20%; left: 0; }
  .node-b { top: 20%; left: 60%; }
  .node-c { top: 60%; left: 100%; }

  .data-box {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    font-family: var(--font-mono);
    color: var(--accent-cyan);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 0.5rem;
    border: 1px dashed var(--accent-cyan);
  }

  /* Systems Section */
  .systems-section {
    padding: 4rem 0;
  }

  .section-heading {
    margin-bottom: 3rem;
  }

  .subtitle-tech {
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .tech-icon {
    font-size: 2rem;
  }

  .technical-panel h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  /* Metrics Section */
  .metrics-section {
    padding: 2rem 0;
  }

  .metrics-panel {
    text-align: center;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 3rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .metric-label {
    font-size: 0.9rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Contact Section */
  .contact-section {
    padding: 2rem 0 6rem;
  }

  .align-center {
    align-items: center;
  }

  .tech-specs-list {
    margin-top: 2rem;
    border-top: 1px solid var(--border-light);
  }

  .spec-row {
    display: flex;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-light);
  }

  .spec-term {
    flex: 0 0 40%;
    font-family: var(--font-mono);
    color: var(--accent-cyan);
  }

  .spec-def {
    flex: 1;
    color: var(--text-primary);
  }

  .cta-panel {
    text-align: center;
  }

  .phone-display {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2rem 0;
    letter-spacing: 0.05em;
  }

  .btn-block {
    display: block;
    width: 100%;
  }

  .text-center {
    text-align: center;
  }

  /* Mobile Adjustments */
  @media (max-width: 900px) {
    .hero-grid, .contact-section .grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-tech {
      padding: 3rem 0;
    }
  }

  @media (max-width: 640px) {
    .metrics-panel .grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .hero-actions {
      flex-direction: column;
    }
    
    .spec-row {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
