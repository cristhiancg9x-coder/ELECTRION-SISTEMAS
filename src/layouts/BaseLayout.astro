---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Venta e instalación de sistemas eléctricos de alta confiabilidad por un electricista profesional en Arequipa y Moquegua, Perú." } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Basics -->
		<title>{title} | ElectriOn Sistemas</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={Astro.url.href} />
		
		<!-- Open Graph -->
		<meta property="og:title" content={`${title} | ElectriOn Sistemas`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		
		<!-- JSON-LD for Local Business -->
		<script type="application/ld+json" set:html={JSON.stringify({
			  "@context": "https://schema.org",
			  "@type": "Electrician",
			  "name": "ElectriOn Sistemas",
			  "description": description,
			  "telephone": "+51951413458",
			  "areaServed": [
			    {
			      "@type": "City",
			      "name": "Arequipa"
			    },
			    {
			      "@type": "City",
			      "name": "Moquegua"
			    }
			  ],
			  "address": {
			    "@type": "PostalAddress",
			    "addressCountry": "PE"
			  }
		})} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>
